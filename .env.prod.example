# .env.prod.example
# ─────────────────────────────────────────────────────────────────────────────
# Template de variables de entorno para PRODUCCIÓN.
#
# Uso:
#   cp .env.prod.example .env.prod
#   nano .env.prod          # completar con valores reales
#
# NUNCA commitear .env.prod al repositorio Git.
# El .gitignore ya incluye esta exclusión.
# ─────────────────────────────────────────────────────────────────────────────

COMPOSE_PROJECT_NAME=acompanarte_prod

# ── Base de datos ─────────────────────────────────────────────────────────────
DB_USER=acomp_user
DB_PASSWORD=CAMBIAR_contrasena_muy_segura_minimo_20_caracteres
DB_NAME=acompanarte_db

# ── Seguridad JWT ─────────────────────────────────────────────────────────────
# Generar con: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CAMBIAR_generar_con_python_secrets_token_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Cifrado de datos sensibles ────────────────────────────────────────────────
# Generar con: python3 -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=CAMBIAR_generar_con_python_secrets_token_hex_32

# ── Módulo de IA ──────────────────────────────────────────────────────────────
# qwen2.5:3b para servidores con 8 GB RAM
# llama3.1:8b para servidores con 16+ GB RAM (mejor calidad)
OLLAMA_MODEL=qwen2.5:3b
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Scheduler del batch de embeddings clínicos (registros, actividades, progresos)
# Formato cron UTC — "0 6 * * *" = 3am ART (UTC-3), todos los días
# Usar "disabled" para desactivar el batch automático
EMBEDDING_BATCH_SCHEDULE=0 6 * * *

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL relativa: el frontend llama al mismo dominio y Nginx hace el proxy
# NO cambiar este valor salvo que tengas dominios separados para API y frontend
VITE_API_URL=/api/v1
